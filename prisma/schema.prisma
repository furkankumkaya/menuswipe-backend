generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id              String       @id @default(uuid())
  name            String
  slug            String       @unique
  logoUrl         String?
  accentColor     String       @default("#8E1616")
  currency        String       @default("USD")
  
  phone           String?
  website         String?
  instagram       String?
  facebook        String?
  
  country         String?
  city            String?
  address         String?
  postalCode      String?
  
  googleMapsUrl   String?
  googlePlaceId   String?
  latitude        Float?
  longitude       Float?
  
  workingHours    Json?
  
  // Subscription
  plan                String    @default("TRIAL")  // TRIAL, STARTER, PRO
  subscriptionStatus  String    @default("TRIAL")  // TRIAL, ACTIVE, EXPIRED, GRACE
  billingCycle        String?                       // MONTHLY, YEARLY
  trialEndsAt         DateTime?
  subscriptionEndsAt  DateTime?
  stripeCustomerId    String?
  stripeSubscriptionId String?
  
  // Languages
  defaultLanguage     String    @default("en")
  enabledLanguages    String[]  @default([])
  
  // Onboarding
  onboardingCompleted Boolean   @default(false)
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  
  users           User[]
  branches        Branch[]
  menuItems       MenuItem[]
  views           MenuView[]
  categories      Category[]
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  passwordHash   String
  name           String
  role           String       @default("OWNER")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
}

model Branch {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  name            String
  slug            String
  active          Boolean      @default(true)
  
  phone           String?
  
  country         String?
  city            String?
  address         String?
  postalCode      String?
  
  googleMapsUrl   String?
  googlePlaceId   String?
  latitude        Float?
  longitude       Float?
  
  workingHours    Json?
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  
  itemBranches    MenuItemBranch[]
  views           MenuView[]
  
  @@unique([organizationId, slug])
}

model Category {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  code            String
  label           String
  color           String       @default("#8E1616")
  visible         Boolean      @default(true)
  sortOrder       Int          @default(0)
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  
  translations    CategoryTranslation[]
  
  @@unique([organizationId, code])
}

model CategoryTranslation {
  id          String   @id @default(uuid())
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  language    String
  label       String
  isManualOverride Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([categoryId, language])
  @@index([categoryId])
}

model MenuItem {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  name            String
  description     String?
  price           Float
  category        String       @default("MAIN")
  
  active          Boolean      @default(true)
  isBestseller    Boolean      @default(false)
  isProperName    Boolean      @default(false)
  
  // Tag sistemi
  tagMarketing    String?
  tagDietary      String?
  
  sortOrder       Int          @default(0)
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  
  photos          MenuPhoto[]
  itemBranches    MenuItemBranch[]
  translations    MenuItemTranslation[]
}

model MenuItemTranslation {
  id              String   @id @default(uuid())
  menuItemId      String
  menuItem        MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  language        String
  name            String
  description     String?
  isManualOverride Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([menuItemId, language])
  @@index([menuItemId])
}

model MenuItemBranch {
  id          String    @id @default(uuid())
  menuItemId  String
  menuItem    MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  branchId    String
  branch      Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  
  @@unique([menuItemId, branchId])
}

model MenuPhoto {
  id           String   @id @default(uuid())
  menuItemId   String
  menuItem     MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  url          String
  cloudinaryId String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
}

model MenuView {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branchId        String?
  branch          Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  
  fromQr          Boolean      @default(false)
  itemId          String?
  category        String?
  
  userAgent       String?
  ipHash          String?
  
  createdAt       DateTime     @default(now())
  
  @@index([organizationId, createdAt])
  @@index([branchId, createdAt])
}
