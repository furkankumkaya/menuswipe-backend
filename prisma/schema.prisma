// schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id              String       @id @default(uuid())
  name            String
  slug            String       @unique
  logoUrl         String?
  accentColor     String       @default("#8E1616")
  currency        String       @default("USD")
  
  // Contact
  phone           String?
  website         String?
  instagram       String?
  facebook        String?
  
  // Address
  country         String?
  city            String?
  address         String?
  postalCode      String?
  
  // Maps
  googleMapsUrl   String?
  googlePlaceId   String?
  latitude        Float?
  longitude       Float?
  
  // Working hours (JSON: {"mon": {"open": "09:00", "close": "22:00"}, ...})
  workingHours    Json?
  
  // Plan
  plan            String       @default("FREE")
  stripeCustomerId String?
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  
  users           User[]
  branches        Branch[]
  menuItems       MenuItem[]
  views           MenuView[]
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  passwordHash   String
  name           String
  role           String       @default("OWNER")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
}

model Branch {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  name            String
  slug            String
  active          Boolean      @default(true)
  
  // Contact
  phone           String?
  
  // Address
  country         String?
  city            String?
  address         String?
  postalCode      String?
  
  // Maps
  googleMapsUrl   String?
  googlePlaceId   String?
  latitude        Float?
  longitude       Float?
  
  // Working hours
  workingHours    Json?
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  
  itemBranches    MenuItemBranch[]
  views           MenuView[]
  
  @@unique([organizationId, slug])
}

model MenuItem {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  name            String
  description     String?
  price           Float
  category        String       @default("MAIN")
  
  active          Boolean      @default(true)
  isBestseller    Boolean      @default(false)
  sortOrder       Int          @default(0)
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  
  photos          MenuPhoto[]
  itemBranches    MenuItemBranch[]
}

model MenuItemBranch {
  id          String    @id @default(uuid())
  menuItemId  String
  menuItem    MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  branchId    String
  branch      Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  
  @@unique([menuItemId, branchId])
}

model MenuPhoto {
  id           String   @id @default(uuid())
  menuItemId   String
  menuItem     MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  url          String
  cloudinaryId String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
}

model MenuView {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branchId        String?
  branch          Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  
  fromQr          Boolean      @default(false)
  itemId          String?      // hangi item'a en çok bakıldı
  category        String?
  
  userAgent       String?
  ipHash          String?      // unique visitor için hash'lenmiş IP
  
  createdAt       DateTime     @default(now())
  
  @@index([organizationId, createdAt])
  @@index([branchId, createdAt])
}
